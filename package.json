{
  "name": "todos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "todos": "src/cli/main.ts"
  },
  "scripts": {
    "build:web": "bun build src/web/entry.tsx --outdir=public/dist --target=browser --entry-naming=[name]-[hash].js",
    "build": "rm -rf public/dist && bun run build:web",
    "start": "bun run build && bun run src/api/server.ts",
    "dev": "bun run build && bun --hot src/api/server.ts",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  }
}
