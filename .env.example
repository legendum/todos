# Copy to .env and adjust. The CLI reads TODOS_WEBHOOK from the project directory.

# Webhook URL for `todos` CLI sync (shown per list in the app)
# TODOS_WEBHOOK=https://todos.in/w/01XXXXXXXXXXXXXXXXXXXXXXXX

# --- Server (optional) ---
# PORT=3000
# HOST=0.0.0.0
# DEV=1

# SQLite database path (self-host)
# TODOS_DB_PATH=data/todos.db

# Session cookies — set in hosted / Legendum mode
# TODOS_COOKIE_SECRET=

# Public base URL for links
# TODOS_DOMAIN=http://localhost:3000
